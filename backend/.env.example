# Copy to .env and adjust as needed. All of these have sane defaults; nothing here is required
# to get started other than Docker running on the host.

# Port the web server (backend API + frontend) listens on.
PORT=7890

# Bind address for the HTTP server.
BIND_ADDR=0.0.0.0

# Directory used for the SQLite database, workspaces, and artifacts.
DATA_DIR=data

# Secret used to sign session JWTs. If unset, one is generated and persisted under
# DATA_DIR/secrets/jwt.key on first run.
# JWT_SECRET=

# 32-byte base64 key used to encrypt PATs/webhook secrets at rest. If unset, one is generated
# and persisted under DATA_DIR/secrets/encryption.key on first run. Back this file up; losing
# it makes stored PATs and webhook secrets unrecoverable.
# ENCRYPTION_KEY=

# Override for the Docker Engine connection (defaults to the platform-local socket/pipe).
# Useful if Docker Desktop's backend exposes a nonstandard socket, e.g. under WSL2.
# DOCKER_HOST=

# Maximum number of jobs that may run concurrently across all workflow runs.
MAX_CONCURRENT_JOBS=4
