# Copy to .env and adjust as needed. Everything else (port, bind address, Docker host override,
# max concurrent jobs) is stored in SQLite and managed via `actions-toolkit start --flag` (port,
# bind address) or the Settings page in the UI (bind address, Docker host, max concurrent jobs).

# Directory used for the SQLite database, workspaces, and artifacts. Defaults to an OS-standard
# per-user data directory (e.g. ~/.local/share/actions-toolkit, %LOCALAPPDATA%\actions-toolkit).
# DATA_DIR=

# Secret used to sign session JWTs. If unset, one is generated and persisted under
# DATA_DIR/secrets/jwt.key on first run.
# JWT_SECRET=

# 32-byte base64 key used to encrypt PATs/webhook secrets at rest. If unset, one is generated
# and persisted under DATA_DIR/secrets/encryption.key on first run. Back this file up, losing
# it makes stored PATs and webhook secrets unrecoverable.
# ENCRYPTION_KEY=

# Client ID of the GitHub App used for the "Connect GitHub" OAuth flow. This is a public value
# (not a secret) shared by every actions-toolkit install, so you don't need to set this unless
# you've registered your own GitHub App for a fork. Defaults to the actions-toolkit App:
# https://github.com/settings/apps/actionstoolkit (client ID Iv23liCp6juYQps4Dxdu).
# GITHUB_APP_CLIENT_ID=
